generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String
  createdAt    DateTime @default(now())
  password     String
  role         Role
  updatedAt    DateTime @updatedAt
  refreshToken        String?
  isVerified          Boolean   @default(false)
  verificationCode    String?
  verificationCodeAt  DateTime?
  resetToken          String?
  resetTokenAt        DateTime?

  workerAvailabilities WorkerAvailability[] @relation("WorkerAvailabilityWorker")
  clientReservations    Reservation[]       @relation("ReservationClient")
  workerReservations    Reservation[]       @relation("ReservationWorker")
  devices               Device[]
  workerWorkOrders      WorkOrder[]         @relation("WorkOrderWorker")
  workOrderHistories    WorkOrderHistory[]
}

model Service {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String
  price       Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reservations Reservation[]
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String
  price       Int
  stock       Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WorkerAvailability {
  id          Int      @id @default(autoincrement())
  workerId    Int
  dayOfWeek   Int
  startTime   String
  endTime     String
  slotMinutes Int      @default(60)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  worker User @relation("WorkerAvailabilityWorker", fields: [workerId], references: [id])

  @@index([workerId, dayOfWeek])
}

model Reservation {
  id            Int               @id @default(autoincrement())
  clientId      Int
  workerId      Int
  serviceId     Int
  scheduledAt   DateTime
  clientNotes   String?
  contactPhone  String
  depositAmount Int               @default(0)
  status        ReservationStatus @default(PENDING)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  client  User    @relation("ReservationClient", fields: [clientId], references: [id])
  worker  User    @relation("ReservationWorker", fields: [workerId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])
  workOrders WorkOrder[]

  @@unique([workerId, scheduledAt])
  @@index([clientId, scheduledAt])
}

model Device {
  id           Int      @id @default(autoincrement())
  clientId     Int
  brand        String
  model        String
  serialNumber String?
  deviceType   String
  description  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client     User          @relation(fields: [clientId], references: [id])
  photos     DevicePhoto[]
  workOrders WorkOrder[]

  @@index([clientId])
}

model DevicePhoto {
  id          Int      @id @default(autoincrement())
  deviceId    Int
  url         String
  description String?
  createdAt   DateTime @default(now())

  device Device @relation(fields: [deviceId], references: [id])

  @@index([deviceId])
}

model WorkOrder {
  id                 Int             @id @default(autoincrement())
  deviceId           Int
  workerId           Int
  reservationId      Int?
  problemDescription String
  diagnosis          String?
  laborCost          Int             @default(0)
  status             WorkOrderStatus @default(RECEIVED)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  device             Device             @relation(fields: [deviceId], references: [id])
  worker             User               @relation("WorkOrderWorker", fields: [workerId], references: [id])
  reservation        Reservation?       @relation(fields: [reservationId], references: [id])
  workOrderHistories WorkOrderHistory[]

  @@index([deviceId])
  @@index([workerId])
}

model WorkOrderHistory {
  id              Int             @id @default(autoincrement())
  workOrderId     Int
  previousStatus  WorkOrderStatus
  newStatus       WorkOrderStatus
  createdAt       DateTime        @default(now())
  changedByUserId Int
  changedBy       User            @relation(fields: [changedByUserId], references: [id])
  workOrder       WorkOrder       @relation(fields: [workOrderId], references: [id])

  @@index([changedByUserId])
  @@index([workOrderId, createdAt])
}

enum Role {
  ADMIN
  WORKER
  CLIENT
  SUPER_ADMIN
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  ATTENDED
  CANCELLED
  NO_SHOW
}

enum WorkOrderStatus {
  RECEIVED
  DIAGNOSIS
  WAITING_PARTS
  IN_REPAIR
  READY
  DELIVERED
  CANCELLED
}
